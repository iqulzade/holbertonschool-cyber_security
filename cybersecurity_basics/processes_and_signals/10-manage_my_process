#!/usr/bin/env bash
# 10-manage_my_process
PIDFILE="/tmp/my_process.pid"

case "$1" in
  start)
    ./manage_my_process &
    pid=$!
    echo "$pid" > "$PIDFILE"
    echo "manage_my_process started"
    ;;

  stop)
    if [ -f "$PIDFILE" ]; then
      pid=$(cat "$PIDFILE")
      kill "$pid" 2>/dev/null
      sleep 1
      kill -9 "$pid" 2>/dev/null
      rm -f "$PIDFILE"
    fi
    echo "manage_my_process stopped"
    ;;

  restart)
    if [ -f "$PIDFILE" ]; then
      pid=$(cat "$PIDFILE")
      kill "$pid" 2>/dev/null
      sleep 1
      kill -9 "$pid" 2>/dev/null
      rm -f "$PIDFILE"
    fi

    ./manage_my_process &
    pid=$!
    echo "$pid" > "$PIDFILE"
    echo "manage_my_process restarted"
    ;;

  *)
    echo "Usage: manage_my_process {start|stop|restart}"
    ;;
esac